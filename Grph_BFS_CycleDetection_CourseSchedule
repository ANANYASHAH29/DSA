class Solution {
    public boolean canFinish(int numCourses, int[][] prerequisites) {
        List<List<Integer>> adj=new ArrayList<>(); //build the graph first
        for(int i=0;i<numCourses;i++){
            adj.add(new ArrayList<>());
        }
        int[] indegree=new int[numCourses]; //track the number of prerequisites for each node=course
        for(int[] p:prerequisites){
            int course=p[0];
            int pre=p[1];
            adj.get(pre).add(course);
            indegree[course]++;
        }
        Queue<Integer> q=new LinkedList<>();
        for(int i=0;i<numCourses;i++){ //q has all nodes with no prerequisites->indegree=0
            if(indegree[i]==0)
               q.offer(i);
        }
        int c=0;
        while(!q.isEmpty()){
            int node=q.poll();
            c++;
            for(int nei:adj.get(node)){
                indegree[nei]--; //reduce the prereq count for the node once visited and enter q if 0
                if(indegree[nei]==0){
                    q.offer(nei);
                }
            }
        }
        return c==numCourses; //when all nodes=courses visited, return
    }
}
